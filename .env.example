# Supabase Config
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe Config
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_STARTER=price_starter_10
STRIPE_PRICE_ID_STANDARD=price_standard_15
STRIPE_PRICE_ID_ALLACCESS=price_allaccess_25
STRIPE_PRICE_ID_AI_ADDON=price_ai_addon_10
STRIPE_PAYMENT_LINK_WATCHTHEDEV=https://buy.stripe.com/test_watch_dev

# AI — Bring-Your-Own-Key (BYOK)
# Every app is AI-integrated; users supply their own provider key
# (Claude / OpenAI / Gemini / Grok) in Settings. Keys are stored per-user,
# server-side, via a shared callAI() adapter — no single platform key required.
# Optional platform key only for the hosted SaaS AI add-on (one provider):
# AI_PLATFORM_PROVIDER=gemini
# AI_PLATFORM_KEY=your-platform-key

# App / Site Config
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Dev Journey "unlock" CTA points here (payment handled on Kickstarter)
NEXT_PUBLIC_KICKSTARTER_URL=https://www.kickstarter.com/projects/your-campaign
NODE_ENV=development
