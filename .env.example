# Supabase Config
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI — Bring-Your-Own-Key (BYOK, any provider)
# Users supply their own key in Settings (stored encrypted, per-user). There is
# no shared server-side key paid for by you. These are only local-dev defaults
# for the shared callAI() adapter.
AI_PROVIDER=openai            # openai | gemini | anthropic | openrouter
AI_API_KEY=your-own-api-key   # the user's own key
AI_MODEL=gpt-4o-mini          # default model — swap without redeploying

# App / Site Config
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Dev Journey "unlock" CTA points here (payment handled on Kickstarter)
NEXT_PUBLIC_KICKSTARTER_URL=https://www.kickstarter.com/projects/your-campaign
NODE_ENV=development

# NOTE: Stripe is NOT part of this project — Kickstarter handles pledges and
# there is no in-app billing. STRIPE_* vars belong only to the future
# standalone SaaS phase. See VOID_OS_Master_Plan.md.
